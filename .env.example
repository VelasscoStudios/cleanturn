DATABASE_URL="file:./dev.db"
SESSION_SECRET=replace-with-openssl-rand-hex-32
CRON_SECRET=replace-with-openssl-rand-hex-32
APP_URL=http://localhost:3100
APP_TIMEZONE=America/Edmonton
ADMIN_EMAIL=admin@cleanturn.local
# Set a strong password before seeding. In production the seed REQUIRES this to
# be set and rejects the local demo default (see prisma/seed.ts).
ADMIN_INITIAL_PASSWORD=change-me-before-seeding

# Day-one kill switch for the notification pipeline (SMS/WhatsApp/email). Keep false until providers are wired.
NOTIFICATIONS_ENABLED=false
